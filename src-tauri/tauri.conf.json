{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Alias Studio Code",
  "version": "0.1.0",
  "identifier": "com.alan.aliasstudiocode",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Alias Studio Code",
        "maximized": true,
        "decorations": false,
        "height": 700,
        "width": 950
      }
    ],
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../LICENSE.txt"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
